{
  "version": 2,
  "builds": [
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.js"
    },
    {
      "src": "/logo-ayana-baru.png",
      "dest": "/public/logo-ayana-baru.png"
    },
    {
      "src": "/kasir",
      "dest": "/public/kasir.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}